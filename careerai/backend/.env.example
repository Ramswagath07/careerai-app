# App
APP_NAME=CareerAI
DEBUG=false
ENVIRONMENT=production

# Security — CHANGE THESE IN PRODUCTION
JWT_SECRET_KEY=your-super-secret-jwt-key-change-me
SECRET_KEY=your-app-secret-key-change-me

# Database
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true
DB_NAME=careerai

# CORS
ALLOWED_ORIGINS=["https://careerai.vercel.app","http://localhost:5173"]

# File Upload
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=uploads
